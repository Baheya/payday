  "imports": {
    "#src/*": "./src/*",
    "#icons/*": "./src/assets/icons/*",
    "#components/*": "./src/components/*",
    "#db/*": "./src/db/*",
    "#lib/*": "./src/lib/*",
    "#styles/*": "./src/styles/*",
    "#layouts/*": "./src/layouts/*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "*.{js,css,md,ts,tsx,jsx,astro}": "prettier --write"
  }
