{
  "scripts": {
    "dev": "astro dev",
    "dev:local": "astro dev --host test.payday.com --port 443",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "prepare": "husky && husky install",
    "check": "astro check && tsc --noEmit",
    "lint": "npm run format && eslint --ext .ts --ext .tsx --ext .js --ext .jsx --ext astro .",
    "format": "prettier --write . && stylelint \"**/*.css\" --fix",
    "test": "vitest run",
    "test:browser": "vitest --config=vitest.browser.config.ts",
    "regenerate-database-types-and-schemas": "npx supabase gen types typescript --project-id lupubdmaaafipiyzqnbv --schema public > src/db/types.ts && npx supazod -i src/db/types.ts -o schemas.ts --inline-types"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/netlify": "^7.0.12",
    "@hcaptcha/vanilla-hcaptcha": "^1.1.4",
    "@unpic/astro": "^1.0.2",
    "astro": "^6.4.4",
    "minisearch": "^7.2.0"
  },
  "overrides": {
    "@unpic/astro": {
      "astro": "$astro"
    },
    "vitest-browser-astro": {
      "astro": "$astro"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  },
  "name": "payday-app",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "devDependencies": {
    "@csstools/css-syntax-patches-for-csstree": "^1.1.5",
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "@hcaptcha/types": "^1.2.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.2",
    "@types/node": "^25.9.2",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/browser-playwright": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.7.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^17.0.7",
    "modern-normalize": "^3.0.1",
    "playwright": "^1.60.0",
    "postcss-mixins": "^12.1.2",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.12.0",
    "stylelint-config-clean-order": "^10.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-media-use-custom-media": "^4.1.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "supazod": "^4.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8",
    "vitest-browser-astro": "^0.2.0"
  },
  "imports": {
    "#icons/*": "./src/assets/icons/*",
    "#components/*": "./src/components/*",
    "#db/*": "./src/db/*",
    "#lib/*": "./src/lib/*",
    "#styles/*": "./src/styles/*",
    "#layouts/*": "./src/layouts/*",
    "#actions/*": "./src/actions/*",
    "#images/*": "./src/images/*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "*.{js,css,md,ts,tsx,jsx,astro}": "prettier --write"
  }
}
