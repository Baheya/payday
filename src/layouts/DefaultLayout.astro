---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <div class="container">
    <slot />
  </div>
</BaseLayout>

<style>
  .container {
    padding-inline: var(--spacing-200);
    width: 100%;
    height: 100%;
    container: main / inline-size;

    @media (--md-viewport) {
      padding-inline: var(--spacing-500);
    }
  }
</style>
