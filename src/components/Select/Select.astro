---
import type { ComponentProps } from "astro/types";

import SelectOnlyCombobox from "#components/SelectOnlyCombobox/SelectOnlyCombobox.astro";

interface Props {
  id: string;
  label: string;
  options: ComponentProps<typeof SelectOnlyCombobox>["options"];
  formControlId?: string;
  name: string;
}

const { id, label, options, formControlId, ...props } = Astro.props;
---

<SelectOnlyCombobox
  comboboxLabel={label}
  data-combobox-select
  formControlId={formControlId}
  id={id}
  options={options}
  {...props}
/>
