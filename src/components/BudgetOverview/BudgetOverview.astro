---
import type { BudgetExpensesByCategory } from "#db/budgets.ts";

import ExpenseDetail from "#components/ExpenseDetail/ExpenseDetail.astro";
import Heading from "#components/Heading/Heading.astro";
import Link from "#components/Link/Link.astro";
import { setCurrency } from "#lib/utils.ts";

import style from "./style.module.css";

interface Props {
  expenses: BudgetExpensesByCategory[];
  summary?: "budgets" | "expenses";
}

const { expenses, summary = "budgets" } = Astro.props;

const budgetMaximum = expenses.reduce(
  (acc, expense) => acc + expense.maximum,
  0,
);
const expensesTotalSpend = expenses.reduce(
  (acc, expense) => acc + Math.abs(expense.totalSpent || 0),
  0,
);

const generatedGradientStops = expenses.reduce((acc, expense) => {
  let gradientStart;

  const budgetColor = expense.theme_id;
  const gradientEnd =
    (Math.abs(expense.totalSpent || 0) / expensesTotalSpend) * 100;
  const gradient =
    acc +
    `${!acc ? "" : ", "}var(--${budgetColor}) ${gradientStart || 0}% ${gradientEnd.toFixed(0)}%`;
  gradientStart = gradientEnd;
  return gradient;
}, "");

const styleAttribute = {
  style: { background: `conic-gradient(${generatedGradientStops})` },
};
---

<section class={style.container}>
  <div class={style.overview}>
    <div class={style.header}>
      <Heading as="h2" size="lg">Budgets</Heading>
      <Link href="/budgets">See Details</Link>
    </div>
    <div class={style.main}>
      <div class={style.wrapper}>
        <div class={style.chart} {...styleAttribute}></div>
        <div class={style.inner}>
          <div class={style.text}>
            <span class={style.emphasis}>{setCurrency(expensesTotalSpend)}</span
            > of {setCurrency(budgetMaximum)} limit
          </div>
        </div>
      </div>
      {summary === "expenses" && <p class={style.summary}>Spending Summary</p>}
      <ul class={style.details}>
        {
          expenses.map((expense) => (
            <ExpenseDetail
              color={expense.theme_id.toString()}
              label={expense.category_id.toString()}
              {...(summary === "expenses" && {
                totalSpent: setCurrency(expense.totalSpent),
              })}
              value={setCurrency(expense.maximum)}
            />
          ))
        }
      </ul>
    </div>
  </div>
</section>
