---
import type { ComponentProps } from "astro/types";

import SelectOnlyCombobox from "#components/SelectOnlyCombobox/SelectOnlyCombobox.astro";

interface Props {
  options: ComponentProps<typeof SelectOnlyCombobox>["options"];
}

const { options } = Astro.props;

const currentlySelected = Astro.url.searchParams.get("filter");
---

<SelectOnlyCombobox
  comboboxLabel="Filter By"
  currentlySelected={decodeURIComponent(currentlySelected || "")}
  data-combobox-filter
  id="filter-combo"
  mobileTriggerIconName="filter"
  options={options}
/>

<script>
  document.querySelectorAll("[data-combobox-filter]").forEach((combobox) => {
    combobox?.querySelectorAll("[role=option]").forEach((element, i) => {
      element.addEventListener("selection-change", (e) => {
        if (e instanceof CustomEvent) {
          const currentParams = new URLSearchParams(window.location.search);
          if (i !== 0) {
            currentParams.set("filter", e.detail);
          } else {
            currentParams.delete("filter");
          }
          window.location.assign(`?${currentParams.toString()}`);
        }
      });
    });
  });
</script>
