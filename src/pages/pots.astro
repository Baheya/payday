---
import Heading from "#components/Heading/Heading.astro";
import PotsDetailCard from "#components/PotsDetailCard/PotsDetailCard.astro";
import DefaultLayout from "#layouts/DefaultLayout.astro";
import { createSbClient } from "#lib/supabase.ts";
import { actions } from "astro:actions";

const supabase = createSbClient({
  request: Astro.request,
  cookies: Astro.cookies,
});
// @ts-expect-error due to casting the SSR client to the Browser client
const user = await supabase.auth.getUser();

if (!user?.data) {
  Astro.redirect("/signin");
}

const { data } = await Astro.callAction(actions.pots.getAllPots, {});
---

<DefaultLayout title="Pots">
  <section>
    <Heading as="h1" size="xl">Pots</Heading>
    {
      data && data.length > 0 && (
        <ul>
          {data.map((pot) => (
            <PotsDetailCard pot={pot} />
          ))}
        </ul>
      )
    }
  </section>
</DefaultLayout>

<style>
  ul {
    list-style-type: none;
    grid-template-columns: 1fr;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--spacing-300);
    margin-block-start: var(--spacing-400);

    @media (--md-viewport) {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
