---
import AddNewBudget from "#components/AddNewBudget/AddNewBudget.astro";
import Alert from "#components/Alert/Alert.astro";
import BudgetDetailCard from "#components/BudgetDetailCard/BudgetDetailCard.astro";
import BudgetOverview from "#components/BudgetOverview/BudgetOverview.astro";
import DeleteBudget from "#components/DeleteBudget/DeleteBudget.astro";
import EditBudget from "#components/EditBudget/EditBudget.astro";
import Heading from "#components/Heading/Heading.astro";
import DefaultLayout from "#layouts/DefaultLayout.astro";
import { createSbClient } from "#lib/supabase.ts";
import { actions } from "astro:actions";

const supabase = createSbClient({
  request: Astro.request,
  cookies: Astro.cookies,
});
// @ts-expect-error due to casting the SSR client to the Browser client
const response = await supabase.auth.getUser();

if (!response.data.user) {
  return Astro.redirect("/signin");
}

const [
  { data: colorsData, error: colorsError },
  { data: categoriesData, error: categoriesError },
  { data: budgetExpensesData, error: budgetExpensesError },
] = await Promise.all([
  Astro.callAction(actions.colors.getAllColors, {}),
  Astro.callAction(actions.categories.getAllCategories, {}),
  Astro.callAction(actions.budgets.getBudgetExpensesByCategory, {}),
]);

if (colorsError || categoriesError || budgetExpensesError) {
  // handle
  console.error(colorsError || categoriesError || budgetExpensesError);
}

const colorOptions = colorsData?.map((color) => ({
  label: color.label,
  value: color.id,
  id: color.id,
  prefixStyle: color.value,
  disabled: !!color.budgets,
}));
const categoryOptions = categoriesData?.map((category) => ({
  label: category.label,
  value: category.id,
  id: category.id,
  disabled: category.budgets.length > 0,
}));

const actionResults = [
  Astro.getActionResult(actions.budgets.addNewBudget),
  Astro.getActionResult(actions.budgets.editBudget),
  Astro.getActionResult(actions.budgets.deleteBudget),
];
---

{
  categoryOptions && colorOptions && budgetExpensesData && (
    <DefaultLayout title="Budgets">
      <section>
        <div class="header">
          <Heading as="h1" size="xl">
            Budgets
          </Heading>
          <AddNewBudget
            categoryOptions={categoryOptions}
            colorOptions={colorOptions}
          />
        </div>
        {actionResults.map(
          (result) =>
            result?.data && (
              <Alert
                message={result.data.message}
                success={result.data.success}
              />
            ),
        )}

        {budgetExpensesData.length > 0 && (
          <BudgetOverview expenses={budgetExpensesData} summary="expenses" />
        )}
        <ul>
          {budgetExpensesData.map((budget) => (
            <>
              <BudgetDetailCard budget={budget} />
              <EditBudget
                categoryOptions={categoryOptions}
                colorOptions={colorOptions}
                currentBudget={budget}
              />
              <DeleteBudget currentBudget={budget} />
            </>
          ))}
        </ul>
      </section>
    </DefaultLayout>
  )
}

<style>
  ul {
    margin: 0;
    padding: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
    row-gap: var(--spacing-150);
    margin-block-start: var(--spacing-400);

    @media (--lg-viewport) {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-300);
    }
  }

  .header {
    display: flex;
    justify-content: space-between;
    margin-block: var(--spacing-400);
  }
</style>
